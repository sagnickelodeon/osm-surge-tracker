# Base URL of the FastAPI backend (Component 3a). The Next.js server-side proxy
# (app/api/osm/[...path]/route.ts) forwards browser requests here, so this may be a
# plain-HTTP URL even when the dashboard itself is served over HTTPS — the browser
# never talks to the API directly.
#
# Local dev default (used if unset): http://localhost:8000
# Production example:                http://<VM_PUBLIC_IP>:8000
API_BASE_URL=http://localhost:8000

# Shared secret authenticating BOTH dashboard proxies (the read proxy and the /track
# beacon proxy) to the backend. When set, the API rejects any request that doesn't carry
# it, so the API is reachable only through these proxies — not by a client hitting the
# port directly. Must MATCH the backend's TRACK_SECRET (in the VM's secret.env). If unset,
# the read proxy omits it (the API gate is disabled too) and visitor tracking is disabled.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
TRACK_SECRET=
