# update the keys and secrets accordingly
REDIS_HOST=localhost
REDIS_PORT=6379
PROCESSOR_START_ID=$            # $ = new messages only, 0 = replay backlog
GDELT_API_KEY=                  # optional — enables news via GDELT Cloud Events API (gdeltcloud.com)
OPENAI_API_KEY=                 # optional — enables AI explanations (gpt-4o-mini)
AZURE_STORAGE_CONNECTION_STRING=  # optional — enables silver/gold archive + visitor log
AZURE_BLOB_CONTAINER=             # optional — target blob container
API_PARQUET_DIR=                # optional — defaults to <repo>/data/api
APP_ENV=development             # development (default) or production. In production the API
                                #   REFUSES TO START unless TRACK_SECRET is set (fail-closed),
                                #   so a public deploy can never come up with the gate disabled.
TRACK_SECRET=                   # shared secret authenticating the dashboard proxy to the API.
                                #   When set, EVERY API endpoint (except /health) requires it in
                                #   the x-track-secret header, so the API is reachable only through
                                #   the dashboard proxy; POST /track also uses it to trust x-client-ip.
                                #   Unset = API access gate disabled (all endpoints open) AND visitor
                                #   tracking disabled — fine for local dev, set it in production.
                                #   Set the SAME value here and in the dashboard's TRACK_SECRET.
                                #   Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
BRONZE_RETENTION_DAYS=          # retention time for bronze layer data
SILVER_RETENTION_DAYS=          # retention time for silver layer data